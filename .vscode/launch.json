{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: runserver",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": [
        "runserver"
      ],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Browser Windows",
      "runtimeExecutable": "C:\\chrome-win\\chrome.exe",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}/products",
      "disableNetworkCache": true
    }
  ],
  "compounds": [
    {
      "name": "Start Server and Browser",
      "configurations": [
        "Django: runserver",
        "Browser Windows",
      ]
    }
  ]
}